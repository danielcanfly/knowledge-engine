{
  "$id": "knowledge-engine/m26/question-request-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor_id_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "audience": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "conversation_id": {
      "maxLength": 200,
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "parent_request_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "allow_followup_rewrite": {
          "type": "boolean"
        },
        "external_browsing": {
          "const": false
        },
        "max_followup_turns": {
          "maximum": 8,
          "minimum": 0,
          "type": "integer"
        },
        "policy_version": {
          "minLength": 1,
          "type": "string"
        },
        "tool_calls": {
          "const": false
        }
      },
      "required": [
        "policy_version",
        "allow_followup_rewrite",
        "max_followup_turns",
        "external_browsing",
        "tool_calls"
      ],
      "type": "object"
    },
    "question": {
      "maxLength": 12000,
      "minLength": 1,
      "type": "string"
    },
    "release": {
      "$id": "knowledge-engine/m26/release-identity-v1.schema.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "foundation_repository": {
          "minLength": 1,
          "type": "string"
        },
        "foundation_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "release_id": {
          "minLength": 1,
          "type": "string"
        },
        "schema_version": {
          "const": "knowledge-engine-m26-release-identity/v1"
        },
        "source_repository": {
          "minLength": 1,
          "type": "string"
        },
        "source_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "vault_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "release_id",
        "manifest_sha256",
        "source_repository",
        "source_sha",
        "foundation_repository",
        "foundation_sha"
      ],
      "title": "M26 Release Identity",
      "type": "object"
    },
    "request_id": {
      "pattern": "^m26req_[a-f0-9]{32}$",
      "type": "string"
    },
    "requested_format": {
      "enum": [
        "concise",
        "standard",
        "detailed",
        "structured",
        null
      ]
    },
    "requested_language": {
      "maxLength": 32,
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "const": "knowledge-engine-m26-question-request/v1"
    }
  },
  "required": [
    "schema_version",
    "request_id",
    "question",
    "audience",
    "actor_id_hash",
    "created_at",
    "policy",
    "release"
  ],
  "title": "M26 Question Request",
  "type": "object"
}
