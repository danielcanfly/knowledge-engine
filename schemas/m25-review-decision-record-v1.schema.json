{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-engine.local/schemas/m25-review-decision-record-v1.schema.json",
  "title": "M25.6 immutable decision record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sequence", "previous_decision_sha256", "batch_sha256", "review_item_id", "review_state_sha256", "item_id", "candidate_ids", "evidence_identities", "policy_sha256", "calibrated_report_sha256", "reviewer", "reviewer_role", "action", "rationale", "acknowledgements", "mapping_target", "edited_payload", "split_payload", "decided_at", "authority", "canonical_knowledge", "production_authority", "source_write_permitted", "github_pr_creation_permitted", "m25_7_authorized", "decision_sha256"],
  "properties": {
    "schema_version": {"const": "knowledge-engine-m25-6-decision-record/v1"},
    "sequence": {"type": "integer", "minimum": 1},
    "previous_decision_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "batch_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "review_item_id": {"type": "string"},
    "review_state_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "item_id": {"type": "string"},
    "candidate_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_identities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "policy_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "calibrated_report_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "reviewer": {"type": "string"},
    "reviewer_role": {"const": "internal_reviewer"},
    "action": {"enum": ["approve", "map", "edit", "split", "reject", "defer"]},
    "rationale": {"type": "string"},
    "acknowledgements": {"type": "object"},
    "mapping_target": {"type": ["string", "null"]},
    "edited_payload": {"type": ["object", "null"]},
    "split_payload": {"type": ["array", "null"]},
    "decided_at": {"type": "string"},
    "authority": {"const": "admission_decision_only"},
    "canonical_knowledge": {"const": false},
    "production_authority": {"const": false},
    "source_write_permitted": {"const": false},
    "github_pr_creation_permitted": {"const": false},
    "m25_7_authorized": {"const": false},
    "decision_sha256": {"pattern": "^[0-9a-f]{64}$"}
  }
}
