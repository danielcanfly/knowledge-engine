{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-engine.local/schemas/m25-review-audit-export-v1.schema.json",
  "title": "M25.6 audit export",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_sha256", "decision_count", "latest_item_decision_count", "terminal_item_count", "deferred_item_count", "pending_item_count", "review_complete", "admission_ready", "source_write_permitted", "github_pr_creation_permitted", "m25_7_authorized", "records", "authority", "canonical_knowledge", "production_authority", "audit_sha256"],
  "properties": {
    "schema_version": {"const": "knowledge-engine-m25-6-audit-export/v1"},
    "batch_sha256": {"pattern": "^[0-9a-f]{64}$"},
    "decision_count": {"type": "integer", "minimum": 0},
    "latest_item_decision_count": {"type": "integer", "minimum": 0},
    "terminal_item_count": {"type": "integer", "minimum": 0},
    "deferred_item_count": {"type": "integer", "minimum": 0},
    "pending_item_count": {"type": "integer", "minimum": 0},
    "review_complete": {"type": "boolean"},
    "admission_ready": {"type": "boolean"},
    "source_write_permitted": {"const": false},
    "github_pr_creation_permitted": {"const": false},
    "m25_7_authorized": {"const": false},
    "records": {"type": "array", "items": {"type": "object"}},
    "authority": {"const": "audit_only"},
    "canonical_knowledge": {"const": false},
    "production_authority": {"const": false},
    "audit_sha256": {"pattern": "^[0-9a-f]{64}$"}
  }
}
