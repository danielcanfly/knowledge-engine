{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/compiler-extraction-candidate-v1.schema.json",
  "title": "Knowledge Compiler Extraction Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "compiler_run_id",
    "candidate_type",
    "value",
    "evidence_refs",
    "confidence",
    "effective_audience",
    "status",
    "synthesis_eligible",
    "canonical_write_permitted"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-compiler-extraction-candidate/v1"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[a-f0-9]{64}$"
    },
    "compiler_run_id": {
      "type": "string",
      "pattern": "^crun_[a-f0-9]{64}$"
    },
    "candidate_type": {
      "enum": [
        "entity",
        "concept",
        "claim",
        "definition",
        "decision",
        "date",
        "relationship",
        "citation"
      ]
    },
    "value": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000
    },
    "normalized_value": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 10000
    },
    "subject_candidate_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^cand_[a-f0-9]{64}$"
      }
    },
    "object_candidate_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^cand_[a-f0-9]{64}$"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidenceRef"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Ranking metadata only. Confidence never authorizes acceptance or publication."
    },
    "extraction_method": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "effective_audience": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "status": {
      "enum": [
        "candidate",
        "rejected_unsupported"
      ]
    },
    "rejection_reason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    },
    "synthesis_eligible": {
      "type": "boolean"
    },
    "canonical_write_permitted": {
      "const": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "rejected_unsupported"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "synthesis_eligible": {
            "const": false
          },
          "rejection_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "source_map_id",
        "quote_sha256"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "pattern": "^block_[a-f0-9]{64}$"
        },
        "source_map_id": {
          "type": "string",
          "pattern": "^smap_[a-f0-9]{64}$"
        },
        "quote_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
