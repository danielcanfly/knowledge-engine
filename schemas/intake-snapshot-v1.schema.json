{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/intake-snapshot-v1.schema.json",
  "title": "Knowledge OS Immutable Intake Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "snapshot_id",
    "original_uri",
    "connector_type",
    "connector_version",
    "retrieved_at",
    "content_hash",
    "byte_size",
    "mime_type",
    "encoding",
    "license",
    "owner",
    "audience",
    "access_policy",
    "acl_status",
    "source_version",
    "parent_snapshot",
    "storage_location"
  ],
  "properties": {
    "schema_version": {"const": "intake-snapshot/v1"},
    "source_id": {"type": "string", "pattern": "^source_[a-z0-9][a-z0-9_-]{2,127}$"},
    "snapshot_id": {"type": "string", "pattern": "^snap_[a-f0-9]{64}$"},
    "original_uri": {"type": "string", "minLength": 1, "maxLength": 4096},
    "connector_type": {
      "type": "string",
      "enum": [
        "web_url",
        "local_file",
        "pdf",
        "markdown",
        "git_repository_path",
        "google_drive_document",
        "media_derived_markdown",
        "meeting_transcript",
        "database_metadata_export"
      ]
    },
    "connector_version": {"type": "string", "minLength": 1, "maxLength": 128},
    "retrieved_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "byte_size": {"type": "integer", "minimum": 1},
    "mime_type": {"type": "string", "minLength": 1, "maxLength": 255},
    "encoding": {"type": ["string", "null"], "maxLength": 128},
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value", "observation_source"],
      "properties": {
        "status": {"enum": ["resolved", "unresolved"]},
        "value": {"type": ["string", "null"], "maxLength": 512},
        "observation_source": {"enum": ["observed", "operator_asserted", "inherited", "unresolved"]}
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value", "observation_source"],
      "properties": {
        "status": {"enum": ["resolved", "unresolved"]},
        "value": {"type": ["string", "null"], "maxLength": 512},
        "observation_source": {"enum": ["observed", "operator_asserted", "inherited", "unresolved"]}
      }
    },
    "audience": {"enum": ["public", "internal", "confidential", "restricted"]},
    "acl_status": {"enum": ["resolved", "unresolved"]},
    "access_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_type", "principals", "observation_source"],
      "properties": {
        "policy_type": {"enum": ["public", "authenticated", "principal_set", "restricted", "unresolved"]},
        "principals": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "observation_source": {"enum": ["observed", "operator_asserted", "inherited", "unresolved"]},
        "native_evidence_ref": {"type": ["string", "null"], "maxLength": 2048}
      }
    },
    "source_version": {"type": ["string", "null"], "maxLength": 512},
    "parent_snapshot": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^snap_[a-f0-9]{64}$"},
        {"type": "string", "pattern": "^capture_[a-f0-9]{32}$"}
      ]
    },
    "storage_location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "key", "sha256"],
      "properties": {
        "backend": {"enum": ["r2", "filesystem"]},
        "bucket": {"type": ["string", "null"], "maxLength": 255},
        "key": {"type": "string", "pattern": "^intake/v1/raw/sha256/[a-f0-9]{2}/[a-f0-9]{64}$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"acl_status": {"const": "unresolved"}}},
      "then": {"properties": {"audience": {"const": "restricted"}}}
    },
    {
      "if": {"properties": {"access_policy": {"properties": {"policy_type": {"const": "public"}}}}},
      "then": {
        "properties": {
          "audience": {"const": "public"},
          "acl_status": {"const": "resolved"},
          "access_policy": {"properties": {"principals": {"maxItems": 0}}}
        }
      }
    }
  ]
}
