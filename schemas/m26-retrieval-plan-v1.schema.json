{
  "$id": "knowledge-engine/m26/retrieval-plan-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_audiences": {
      "items": {
        "enum": [
          "public",
          "internal",
          "confidential",
          "restricted"
        ]
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "deterministic_key": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "graph": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_depth": {
          "maximum": 2,
          "minimum": 0,
          "type": "integer"
        },
        "max_edges": {
          "maximum": 100,
          "minimum": 0,
          "type": "integer"
        },
        "max_nodes": {
          "maximum": 50,
          "minimum": 0,
          "type": "integer"
        },
        "relation_types": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "enabled",
        "max_depth",
        "max_nodes",
        "max_edges",
        "relation_types"
      ],
      "type": "object"
    },
    "intent": {
      "enum": [
        "lookup",
        "explain",
        "compare",
        "trace_source",
        "navigate_graph",
        "follow_up"
      ]
    },
    "lexical": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "const": true
        },
        "limit": {
          "maximum": 20,
          "minimum": 1,
          "type": "integer"
        },
        "query_terms": {
          "items": {
            "type": "string"
          },
          "maxItems": 100,
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "limit",
        "query_terms"
      ],
      "type": "object"
    },
    "normalized_question": {
      "minLength": 1,
      "type": "string"
    },
    "release": {
      "$id": "knowledge-engine/m26/release-identity-v1.schema.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "foundation_repository": {
          "minLength": 1,
          "type": "string"
        },
        "foundation_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "release_id": {
          "minLength": 1,
          "type": "string"
        },
        "schema_version": {
          "const": "knowledge-engine-m26-release-identity/v1"
        },
        "source_repository": {
          "minLength": 1,
          "type": "string"
        },
        "source_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "vault_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "release_id",
        "manifest_sha256",
        "source_repository",
        "source_sha",
        "foundation_repository",
        "foundation_sha"
      ],
      "title": "M26 Release Identity",
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "schema_version": {
      "const": "knowledge-engine-m26-retrieval-plan/v1"
    }
  },
  "required": [
    "schema_version",
    "request_id",
    "normalized_question",
    "intent",
    "allowed_audiences",
    "lexical",
    "graph",
    "release",
    "deterministic_key"
  ],
  "title": "M26 Retrieval Plan",
  "type": "object"
}
