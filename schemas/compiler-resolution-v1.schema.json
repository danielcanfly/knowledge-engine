{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/compiler-resolution-v1.schema.json",
  "title": "Knowledge Compiler Resolution v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resolution_id",
    "compiler_run_id",
    "candidate_id",
    "outcome",
    "target_ids",
    "evidence_refs",
    "reason_codes",
    "effective_audience",
    "review_status",
    "synthesis_eligible",
    "canonical_write_permitted"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-compiler-resolution/v1"
    },
    "resolution_id": {
      "type": "string",
      "pattern": "^cres_[a-f0-9]{64}$"
    },
    "compiler_run_id": {
      "type": "string",
      "pattern": "^crun_[a-f0-9]{64}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[a-f0-9]{64}$"
    },
    "outcome": {
      "enum": [
        "new_concept",
        "existing_concept_update",
        "alias",
        "duplicate",
        "contradiction",
        "supersession",
        "unresolved_conflict",
        "rejected_unsupported_claim"
      ]
    },
    "target_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:smap|cand)_[a-f0-9]{64}$"
      }
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]{2,119}$"
      }
    },
    "match_observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matchObservation"
      }
    },
    "supersession_basis": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "superseded_target_id",
        "basis",
        "effective_at",
        "evidence_refs"
      ],
      "properties": {
        "superseded_target_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "basis": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "effective_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?:smap|cand)_[a-f0-9]{64}$"
          }
        }
      }
    },
    "effective_audience": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "review_status": {
      "enum": [
        "pending_human_review",
        "pending_conflict_review",
        "pending_security_review",
        "rejected"
      ]
    },
    "synthesis_eligible": {
      "type": "boolean"
    },
    "canonical_write_permitted": {
      "const": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "new_concept"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "target_ids": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "existing_concept_update",
              "alias",
              "duplicate",
              "contradiction",
              "supersession"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "target_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "supersession"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "supersession_basis": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "contradiction",
              "unresolved_conflict"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "review_status": {
            "const": "pending_conflict_review"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "rejected_unsupported_claim"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "review_status": {
            "const": "rejected"
          },
          "synthesis_eligible": {
            "const": false
          }
        }
      }
    }
  ],
  "$defs": {
    "matchObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "method",
        "score",
        "observation_only"
      ],
      "properties": {
        "target_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "observation_only": {
          "const": true
        }
      }
    }
  }
}
