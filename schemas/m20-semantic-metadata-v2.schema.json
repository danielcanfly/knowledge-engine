{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.example/schemas/m20-semantic-metadata-v2.schema.json",
  "title": "Knowledge Engine semantic metadata v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "metadata_sha256",
    "immutable",
    "read_only",
    "production_authority",
    "identities",
    "provider_contract_sha256",
    "benchmark_suite_sha256",
    "model",
    "vectors",
    "documents"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-engine-semantic/v2"},
    "artifact_id": {"type": "string", "pattern": "^semantic-[0-9a-f]{64}$"},
    "metadata_sha256": {"$ref": "#/$defs/sha256"},
    "immutable": {"const": true},
    "read_only": {"const": true},
    "production_authority": {"const": false},
    "provider_contract_sha256": {"$ref": "#/$defs/sha256"},
    "benchmark_suite_sha256": {"$ref": "#/$defs/sha256"},
    "identities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "builder_engine_commit_sha",
        "provider_contract_engine_commit_sha",
        "source_commit_sha",
        "foundation_commit_sha"
      ],
      "properties": {
        "builder_engine_commit_sha": {"$ref": "#/$defs/gitSha"},
        "provider_contract_engine_commit_sha": {"$ref": "#/$defs/gitSha"},
        "source_commit_sha": {"$ref": "#/$defs/gitSha"},
        "foundation_commit_sha": {"$ref": "#/$defs/gitSha"}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provider",
        "provider_implementation",
        "model_id",
        "tokenizer_id",
        "dimension",
        "dtype",
        "endianness",
        "normalized",
        "pooling",
        "input_template",
        "query_template",
        "maximum_input_length",
        "truncation",
        "unicode_normalization"
      ],
      "properties": {
        "dimension": {"type": "integer", "minimum": 1, "maximum": 65536},
        "dtype": {"const": "float32"},
        "endianness": {"const": "little"},
        "normalized": {"const": true},
        "unicode_normalization": {"const": "NFKC"}
      }
    },
    "vectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filename",
        "sha256",
        "byte_length",
        "row_count",
        "dimension",
        "dtype",
        "endianness",
        "normalized"
      ],
      "properties": {
        "filename": {"const": "semantic-vectors.f32"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_length": {"type": "integer", "minimum": 4},
        "row_count": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "dimension": {"type": "integer", "minimum": 1, "maximum": 65536},
        "dtype": {"const": "float32"},
        "endianness": {"const": "little"},
        "normalized": {"const": true}
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "row",
          "concept_id",
          "section_id",
          "language",
          "audience",
          "source_path",
          "source_sha256"
        ],
        "properties": {
          "row": {"type": "integer", "minimum": 0},
          "concept_id": {"type": "string", "minLength": 1},
          "section_id": {"type": "string", "minLength": 1},
          "language": {"enum": ["en", "zh-TW", "mixed"]},
          "audience": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "source_sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
  }
}
