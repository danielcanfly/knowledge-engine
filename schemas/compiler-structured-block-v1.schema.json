{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/compiler-structured-block-v1.schema.json",
  "title": "Knowledge Compiler Structured Block v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "block_id",
    "compiler_run_id",
    "ordinal",
    "kind",
    "text",
    "parent_block_id",
    "source_map_ids",
    "effective_audience",
    "canonical_write_permitted"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-compiler-structured-block/v1"
    },
    "block_id": {
      "type": "string",
      "pattern": "^block_[a-f0-9]{64}$"
    },
    "compiler_run_id": {
      "type": "string",
      "pattern": "^crun_[a-f0-9]{64}$"
    },
    "ordinal": {
      "type": "integer",
      "minimum": 0
    },
    "kind": {
      "enum": [
        "heading",
        "paragraph",
        "list",
        "list_item",
        "code",
        "table",
        "quote",
        "metadata"
      ]
    },
    "level": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 6
    },
    "text": {
      "type": "string",
      "maxLength": 1000000
    },
    "parent_block_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^block_[a-f0-9]{64}$"
    },
    "source_map_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^smap_[a-f0-9]{64}$"
      }
    },
    "effective_audience": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "canonical_write_permitted": {
      "const": false
    }
  }
}
