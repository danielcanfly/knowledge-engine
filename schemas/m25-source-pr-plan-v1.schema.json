{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-engine.local/schemas/m25-source-pr-plan-v1.schema.json",
  "title": "M25.7 deterministic Source PR plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "mode", "predecessor_status", "predecessor_main_seal_sha", "source_repository", "source_base_sha", "source_manifest_sha256", "batch_sha256", "audit_sha256", "authority_sha256", "item_count", "operation_count", "write_operation_count", "no_write_operation_count", "operations", "branch", "pull_request", "exact_plan_approval_required_before_source_write", "source_branch_write_permitted", "github_pr_creation_permitted", "source_pr_merge_permitted", "canonical_knowledge", "production_authority", "release_mutation_permitted", "production_mutation_permitted", "m25_8_authorized", "plan_sha256"],
  "properties": {
    "schema_version": {"const": "knowledge-engine-m25-7-source-pr-plan/v1"},
    "status": {"const": "m25_7_source_pr_plan_candidate"},
    "mode": {"enum": ["live", "test_only"]},
    "predecessor_status": {"const": "m25_6_review_surface_accepted"},
    "predecessor_main_seal_sha": {"const": "134edbcfa3841321d3ea1106d35243b866cb6913"},
    "source_repository": {"type": "string"},
    "source_base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "batch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "audit_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "authority_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "item_count": {"type": "integer", "minimum": 1},
    "operation_count": {"type": "integer", "minimum": 1},
    "write_operation_count": {"type": "integer", "minimum": 0},
    "no_write_operation_count": {"type": "integer", "minimum": 0},
    "operations": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "branch": {"type": "object"},
    "pull_request": {"type": "object"},
    "exact_plan_approval_required_before_source_write": {"const": true},
    "source_branch_write_permitted": {"const": false},
    "github_pr_creation_permitted": {"const": false},
    "source_pr_merge_permitted": {"const": false},
    "canonical_knowledge": {"const": false},
    "production_authority": {"const": false},
    "release_mutation_permitted": {"const": false},
    "production_mutation_permitted": {"const": false},
    "m25_8_authorized": {"const": false},
    "plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
