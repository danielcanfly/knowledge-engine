{
  "$id": "knowledge-engine/m26/release-identity-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "foundation_repository": {
      "minLength": 1,
      "type": "string"
    },
    "foundation_sha": {
      "pattern": "^[a-f0-9]{40}$",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "release_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "knowledge-engine-m26-release-identity/v1"
    },
    "source_repository": {
      "minLength": 1,
      "type": "string"
    },
    "source_sha": {
      "pattern": "^[a-f0-9]{40}$",
      "type": "string"
    },
    "vault_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "release_id",
    "manifest_sha256",
    "source_repository",
    "source_sha",
    "foundation_repository",
    "foundation_sha"
  ],
  "title": "M26 Release Identity",
  "type": "object"
}
