{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/multi-batch/batch-plan.schema.json",
  "title": "Knowledge OS Multi-Batch Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "title",
    "created_at",
    "actor",
    "source_commit_sha",
    "base_production",
    "intended_audiences",
    "source_refs",
    "parent_batch_id",
    "metadata"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-multi-batch-plan/v1"},
    "batch_id": {"type": "string", "pattern": "^mbatch_[a-f0-9]{32}$"},
    "title": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "actor": {"type": "string", "minLength": 1},
    "source_commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "base_production": {"$ref": "#/$defs/productionIdentity"},
    "intended_audiences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["public", "internal", "confidential", "restricted"]}
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "parent_batch_id": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^mbatch_[a-f0-9]{32}$"}
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "productionIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "manifest_sha256", "pointer_sha256"],
      "properties": {
        "release_id": {
          "type": "string",
          "pattern": "^[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$"
        },
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "pointer_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
