{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/multi-batch/operation-request.schema.json",
  "title": "Knowledge OS Multi-Batch Operation Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_id",
    "batch_id",
    "kind",
    "requested_at",
    "actor",
    "expected_batch_state",
    "target_batch_state",
    "candidate_generation",
    "expected_previous_production",
    "evidence_refs",
    "request_nonce",
    "requires_exclusive_production_mutation"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-multi-batch-operation-request/v1"},
    "operation_id": {"type": "string", "pattern": "^mop_[a-f0-9]{32}$"},
    "batch_id": {"type": "string", "pattern": "^mbatch_[a-f0-9]{32}$"},
    "kind": {
      "enum": [
        "plan_batch",
        "start_intake",
        "open_source_review",
        "build_candidate",
        "rebuild_candidate",
        "record_evaluation",
        "prepare_promotion",
        "promote_production",
        "rollback_production",
        "mark_superseded",
        "abandon_batch",
        "close_batch"
      ]
    },
    "requested_at": {"type": "string", "format": "date-time"},
    "actor": {"type": "string", "minLength": 1},
    "expected_batch_state": {"$ref": "#/$defs/batchState"},
    "target_batch_state": {"$ref": "#/$defs/batchState"},
    "candidate_generation": {
      "oneOf": [
        {"type": "null"},
        {"type": "integer", "minimum": 1, "maximum": 9999}
      ]
    },
    "expected_previous_production": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/productionIdentity"}
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "request_nonce": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "minLength": 1}
      ]
    },
    "requires_exclusive_production_mutation": {"type": "boolean"}
  },
  "$defs": {
    "batchState": {
      "enum": [
        "planned",
        "intake_active",
        "source_review",
        "candidate_building",
        "candidate_ready",
        "evaluation_ready",
        "promotion_ready",
        "production_active",
        "superseded",
        "abandoned",
        "closed",
        "rejected"
      ]
    },
    "productionIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_id", "manifest_sha256", "pointer_sha256"],
      "properties": {
        "release_id": {
          "type": "string",
          "pattern": "^[0-9]{8}T[0-9]{6}Z-[a-f0-9]{12}$"
        },
        "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "pointer_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
