          "minItems": 1,
          "type": "array"
        },
        "claim_id": {
          "type": "string"
        },
        "non_final": {
          "const": true
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "text",
        "binding_ids",
        "non_final"
      ],
      "type": "object"
    }
