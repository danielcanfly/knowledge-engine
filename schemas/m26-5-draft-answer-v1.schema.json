      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "safe_for_m26_6": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "knowledge-engine-m26-draft-answer/v1"
    },
    "self_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "status": {
      "enum": [
        "non_final_draft_answer",
        "non_final_draft_answer_with_warnings",
