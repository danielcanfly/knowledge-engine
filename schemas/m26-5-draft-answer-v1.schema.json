  "additionalProperties": false,
  "properties": {
    "answer_text": {
      "type": "string"
    },
    "citation_bindings": {
      "items": {
        "$ref": "#/$defs/citationBinding"
      },
      "type": "array"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/claim"
      },
      "type": "array"
    },
    "context_package_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "diagnostics": {
      "type": "object"
    },
    "final_answer": {
      "const": false
    },
    "privacy_review_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "production_answer_serving": {
      "const": false
    },
