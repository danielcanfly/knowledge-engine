          "type": "string"
        },
        "claim_id": {
          "type": "string"
        },
        "context_manifest_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "context_package_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "passage_id": {
          "type": "string"
        },
        "provider_replay_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
