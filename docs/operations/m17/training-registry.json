      "allowed_remote_operations": [],
      "prerequisites": [],
      "competencies": ["architecture_boundaries", "identity_chain", "safe_stop_judgment"],
      "deliverables": ["four-plane explanation", "boundary map", "universal stop-condition list"],
      "passing_criteria": ["all four planes identified", "Source and derived artifacts distinguished", "stop conditions explained"],
      "stop_conditions": ["candidate treats generated artifacts as canonical truth", "candidate cannot identify mutation boundaries"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/architecture/m17/system-map.md", "anchor": "# Knowledge OS Four-Plane System Map"}
      ]
    },
    {
      "id": "planned_governed_batch",
      "order": 2,
      "title": "Planned governed batch",
      "weight": 15,
      "critical": true,
      "authority_mode": "local_output",
      "allowed_remote_operations": [],
      "prerequisites": ["architecture_orientation"],
      "competencies": ["identity_chain", "evidence_handoffs", "acl_safety", "safe_stop_judgment"],
      "deliverables": ["non-executing batch plan", "identity checklist", "rollback readiness plan"],
      "passing_criteria": ["all lifecycle stages represented", "authority boundaries explicit", "ACL and rollback gates present"],
      "stop_conditions": ["moving branch used as identity", "approval assumed", "production mutation proposed"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/operations/m17/end-to-end-batch-runbook.md", "anchor": "## Canonical sequence"}
      ]
    },
    {
      "id": "source_package_review",
      "order": 3,
      "title": "Source package review",
      "weight": 15,
      "critical": true,
      "authority_mode": "read_only",
      "allowed_remote_operations": [],
      "prerequisites": ["planned_governed_batch"],
      "competencies": ["source_governance", "evidence_handoffs", "privacy_safe_evidence", "safe_stop_judgment"],
      "deliverables": ["fixture review findings", "claim support classification", "ACL and provenance decision"],
      "passing_criteria": ["unsupported claims detected", "contradictions and provenance gaps detected", "ambiguous audience blocks"],
      "stop_conditions": ["raw private content copied", "unsupported claim accepted", "generated output edited as Source"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/operations/m17/end-to-end-batch-runbook.md", "anchor": "### 6. Human review"}
