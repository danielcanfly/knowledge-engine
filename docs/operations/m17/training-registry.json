      "competencies": ["evidence_handoffs", "identity_chain", "privacy_safe_evidence", "safe_stop_judgment"],
      "deliverables": ["isolated lifecycle evidence", "fixture artifact digests", "safe-stop record"],
      "passing_criteria": ["filesystem fixture only", "all outputs digest-bound", "no production or credential access"],
      "stop_conditions": ["production configuration detected", "remote mutation attempted", "evidence identity lost"],
      "minimum_evidence_items": 2,
      "references": [
        {"path": "docs/operations/m17/operator-tooling.md", "anchor": "## Universal safety rules"}
      ]
    },
    {
      "id": "rollback_drill",
      "order": 6,
      "title": "Rollback drill",
      "weight": 15,
      "critical": true,
      "authority_mode": "isolated_fixture",
      "allowed_remote_operations": [],
      "prerequisites": ["non_production_dry_run"],
      "competencies": ["rollback_recovery", "identity_chain", "acl_safety", "safe_stop_judgment"],
      "deliverables": ["incident classification", "governed recovery plan", "post-rollback verification matrix"],
      "passing_criteria": ["uncertain state fails closed", "authority and expected-previous identity identified", "query citation cache pointer and ACL checks included"],
      "stop_conditions": ["real rollback proposed", "missing rollback target", "unknown production state treated as healthy"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/operations/m17/promotion-rollback-recovery.md", "anchor": "## Failed or uncertain promotion"}
      ]
    },
    {
      "id": "closeout_package",
      "order": 7,
      "title": "Closeout package",
      "weight": 15,
      "critical": true,
      "authority_mode": "local_output",
      "allowed_remote_operations": [],
      "prerequisites": ["rollback_drill"],
      "competencies": ["closeout_reconciliation", "privacy_safe_evidence", "identity_chain", "safe_stop_judgment"],
      "deliverables": ["bounded closeout package", "identity and digest inventory", "resume-or-stop decision"],
      "passing_criteria": ["all required identities and evidence digests present", "unresolved items explicit", "package does not claim ledger or closeout mutation"],
      "stop_conditions": ["missing evidence hidden", "raw private material included", "package represented as approval or ledger append"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/operations/m17/end-to-end-batch-runbook.md", "anchor": "### 18. Final reconciliation"}
      ]
    }
