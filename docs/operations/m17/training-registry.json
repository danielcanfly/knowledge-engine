      "weight": 15,
      "critical": true,
      "authority_mode": "read_only",
      "allowed_remote_operations": ["get", "head"],
      "prerequisites": ["source_package_review"],
      "competencies": ["candidate_acceptance", "citation_quality", "acl_safety", "identity_chain"],
      "deliverables": ["candidate identity verification", "acceptance completeness report", "ACL-negative and citation findings"],
      "passing_criteria": ["manifest identity verified", "required acceptance evidence present", "citation and ACL-negative results interpreted"],
      "stop_conditions": ["candidate identity mismatch", "missing acceptance evidence", "ACL broadening or citation failure"],
      "minimum_evidence_items": 1,
      "references": [
        {"path": "docs/operations/m17/operator-tooling.md", "anchor": "| `production-status` |"},
        {"path": "docs/operations/m17/end-to-end-batch-runbook.md", "anchor": "### 11. Candidate acceptance"}
      ]
    },
    {
      "id": "non_production_dry_run",
      "order": 5,
      "title": "Non-production dry run",
      "weight": 15,
      "critical": true,
      "authority_mode": "isolated_fixture",
