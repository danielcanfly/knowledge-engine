      "snapshot_sha256": "e75034a5eb7e350895ea6ddeee3c10013edcefbff1c99c2b14b3ab154341bb53",
      "source_id": "src-latency",
      "source_kind": "markdown",
      "text": "Retrieval latency is measured separately for planning, candidate recall, graph expansion, and evidence assembly.\nTail latency uses p95 and p99 rather than averages alone.",
      "uri": "https://fixture.local/latency"
    },
