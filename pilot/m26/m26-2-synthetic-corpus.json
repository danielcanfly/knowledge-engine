      "source_id": "src-completeness",
      "source_kind": "markdown",
      "text": "Answer completeness is measured against required facets and evidence nuggets.\nA rich evidence set must not be collapsed into an unjustifiably thin answer.",
      "uri": "https://fixture.local/completeness"
    },
    {
      "audience": "internal",
      "content_sha256": "4719ae585ccba6b368a12140785d5b377500c4c9b2f6174d426cdadd28c58de6",
      "current": true,
      "default_locator": {
        "anchor": null,
        "end_line": 2,
