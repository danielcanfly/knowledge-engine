      "snapshot_sha256": "5a2c1a51359abbf98b1700f065676e45c97d6a6c4d47d89e0d752a28ccdd9a48",
      "source_id": "src-citation",
      "source_kind": "markdown",
      "text": "Citation presence alone does not prove support.\nA material claim requires evidence text and a typed locator.\nBounded citation verification blocks citation theatre.",
      "uri": "https://fixture.local/citation"
    },
    {
      "audience": "internal",
      "content_sha256": "cc45fda1b25eee7cd58a04182e6fbe993614fc9eecbf346a8b6a384c963107dd6",
